# ============================================
# .env.example - 환경 설정 템플릿
# ============================================
# 이 파일을 복사해서 .env 파일을 만드세요
# .env 파일은 git에 커밋되지 않습니다 (보안)
#
# 복사 방법:
# 1. 이 파일을 복사해서 .env 파일 생성
# 2. 자신의 정보로 채우기
# 3. git에는 이 파일(.env.example)만 올리기

# ============================================
# 프로젝트 정보
# ============================================
PROJECT_NAME=Project_Newsletter
PROJECT_DESCRIPTION=Game, IT, Crypto, Soccer Weekly Newsletter
AUTHOR_NAME=성찬
AUTHOR_EMAIL=aseongchan23@gmail.com

# ============================================
# 발행 설정
# ============================================
# 발행 요일 (Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday)
PUBLISH_DAY=Tuesday

# 발행 시간 (24시간 형식, 예: 09:00, 14:30)
PUBLISH_TIME=09:00

# 뉴스레터 섹션 활성화
INCLUDE_GAMES=true
INCLUDE_IT=true
INCLUDE_CRYPTO=true
INCLUDE_SOCCER=true

# 섹션별 뉴스 개수
NEWS_PER_SECTION=3

# ============================================
# 팩트 체크 설정
# ============================================
# 팩트 체크 필수 여부
FACT_CHECK_REQUIRED=true

# 최소 출처 개수
MIN_SOURCES=2

# 팩트 체크 담당자 (필요시)
FACT_CHECKER_EMAIL=

# ============================================
# 통지 설정 (추후 자동화용)
# ============================================
# 초안 완성 알림 (이메일, Slack 등)
NOTIFY_ON_DRAFT_COMPLETE=false

# 발행 완료 알림
NOTIFY_ON_PUBLISH=false

# 알림 이메일 (발행 완료 시)
NOTIFICATION_EMAIL=aseongchan23@gmail.com

# ============================================
# 저장소 설정 (Git/GitHub 연동 추후)
# ============================================
# GitHub 레포지토리 (선택사항)
GITHUB_REPO=

# GitHub 토큰 (선택사항 - 절대 커밋하지 마세요!)
GITHUB_TOKEN=

# ============================================
# API 키 (필요시)
# ============================================
# 뉴스 API 키 (NewsAPI, Rapid API 등)
NEWS_API_KEY=

# 데이터 크롤링용 API
DATA_API_KEY=

# ============================================
# 로깅 및 디버그
# ============================================
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 디버그 모드
DEBUG=false

# ============================================
# 기타 설정
# ============================================
# 자동 백업 활성화
AUTO_BACKUP=false

# 백업 폴더 (상대 경로)
BACKUP_DIR=backups/

# 언어 설정
LANGUAGE=ko-KR

# 타임존
TIMEZONE=Asia/Seoul
